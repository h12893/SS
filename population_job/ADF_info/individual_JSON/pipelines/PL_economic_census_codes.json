                    "referenceName": "Connect_population_dynamics_prefecture",
                    "type": "LinkedServiceReference"
                },
                "typeProperties": {
                    "scripts": [
                        {
                            "type": "Query",
                            "text": "-- job_name_2012内の空白削除\nUPDATE economic_census_code\nSET job_name_2012 = TRIM(BOTH ' ' FROM TRIM(BOTH '　' FROM job_name_2012))\n\n-- job_name_2016内の空白削除\nUPDATE economic_census_code\nSET job_name_2016 = TRIM(BOTH ' ' FROM TRIM(BOTH '　' FROM job_name_2016))\n\n-- job_name_2021内の空白削除\nUPDATE economic_census_code\nSET job_name_2021 = TRIM(BOTH ' ' FROM TRIM(BOTH '　' FROM job_name_2021))"
                        }
                    ],
                    "scriptBlockExecutionTimeout": "02:00:00"
                }
            },
