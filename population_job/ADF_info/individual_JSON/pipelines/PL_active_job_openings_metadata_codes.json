                },
                "typeProperties": {
                    "scripts": [
                        {
                            "type": "Query",
                            "text": "IF EXISTS (\n    SELECT 1\n    FROM sys.tables\n    WHERE name = 'active_job_openings_metadata_codes'\n)\nBEGIN\n    DROP TABLE active_job_openings_metadata_codes\nEND;\n\nCREATE TABLE active_job_openings_metadata_codes (\n    job_code INT NOT NULL PRIMARY KEY,\n    job_name_2012_2022 NVARCHAR(200) NOT NULL,   -- 2012~2022年と2023年~で表記が異なる（内容は同じ）なのでカラムを分ける\n    job_name_2023_ NVARCHAR(200) NOT NULL,   -- 2012~2022年と2023年~で表記が異なる（内容は同じ）なのでカラムを分ける\n    classification_code INT,\n    classification NVARCHAR(200),\n    classification_hierarchy_code INT,\n    classification_hierarchy NVARCHAR(200)\n);"
                        }
                    ],
                    "scriptBlockExecutionTimeout": "02:00:00"
                }
            },
            {
                "name": "CleanJobName",
                "description": "",
                "type": "Script",
                "dependsOn": [
                    {
                        "activity": "RawToMetadataCodes",
                        "dependencyConditions": [
                            "Completed"
                        ]
                    }
                ],
                "policy": {
                    "timeout": "0.12:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "linkedServiceName": {
                    "referenceName": "Connect_population_dynamics_prefecture",
                    "type": "LinkedServiceReference"
                },
                "typeProperties": {
                    "scripts": [
                        {
                            "type": "Query",
                            "text": "-- job_name_2012_2022内の空白削除\nUPDATE active_job_openings_metadata_codes\nSET job_name_2012_2022 = TRIM(BOTH ' ' FROM TRIM(BOTH '　' FROM job_name_2012_2022))\n\n-- job_name_2023_内の空白削除\nUPDATE active_job_openings_metadata_codes\nSET job_name_2023_  = TRIM(BOTH ' ' FROM TRIM(BOTH '　' FROM job_name_2023_))\n"
                        }
                    ],
                    "scriptBlockExecutionTimeout": "02:00:00"
                }
            },
